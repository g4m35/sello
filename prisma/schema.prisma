generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InventoryStatus {
  DRAFTING
  DRAFT_READY
  AI_FAILED
  APPROVED
  LISTING
  LISTED
  SOLD
  DELISTING
  DELISTED
  ARCHIVED
}

enum ProductCategory {
  sneakers
  streetwear
  hype_fashion
  accessories
  other
}

enum ItemCondition {
  new_with_tags
  new_without_tags
  used_excellent
  used_good
  used_fair
  for_parts
  unknown
}

enum CompSourceType {
  manual
  api
  scraper
  visual_search
}

enum CompStatus {
  sold
  active
  unknown
}

enum ProviderCallStatus {
  attempted
  succeeded
  failed
  skipped
}

enum UsageReservationStatus {
  reserved
  settled
  released
  expired
  denied
}

enum FeedbackType {
  bug
  feature_request
  confusion
  pricing_issue
  marketplace_issue
  other
}

enum FeedbackSeverity {
  low
  medium
  high
}

enum FeedbackStatus {
  open
  reviewing
  resolved
  dismissed
}

enum DraftStatus {
  DRAFT
  APPROVED
}

enum Marketplace {
  ebay
  grailed
  poshmark
  depop
  etsy
  tiktok_shop
  vinted
  stockx
}

enum MarketplaceListingStatus {
  NOT_LISTED
  QUEUED
  LISTING
  LISTED
  SOLD
  DELISTING
  DELISTED
  FAILED
  // Added for the cross-marketplace inventory safety layer + TikTok Shop audit flow.
  ENDED
  UNKNOWN
  NEEDS_REVIEW
  SUBMITTED_FOR_AUDIT
  REJECTED
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum MarketplaceImageStatus {
  READY
  STALE
  DELETED
  FAILED
}

enum PublishAttemptStatus {
  NOT_IMPLEMENTED
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum BulkBatchStatus {
  created
  uploading
  processing
  needs_review
  ready
  partially_failed
  failed
  canceled
}

enum BulkItemStatus {
  uploaded
  grouping
  ready_for_generation
  generating
  needs_review
  listing_ready
  failed
  canceled
}

model InventoryItem {
  id                    String               @id @default(uuid()) @db.Uuid
  sellerId              String               @db.Uuid
  // Owning account (shared workspace). Nullable during backfill; the app scopes
  // reads by account once present. sellerId stays as the creating member.
  accountId             String?              @db.Uuid
  account               Account?             @relation(fields: [accountId], references: [id])
  status                InventoryStatus      @default(DRAFTING)
  productName           String
  brand                 String?
  category              ProductCategory      @default(other)
  condition             ItemCondition        @default(unknown)
  styleCode             String?
  colorway              String?
  size                  String?
  confidence            Float?
  recommendedPriceCents Int?
  pricingRationale      String?
  soldAt                DateTime?
  // Inventory safety / double-sell prevention (source of truth).
  quantityAvailable     Int                  @default(1)
  soldSourceMarketplace Marketplace?
  soldSourceListingId   String?
  // Optimistic-concurrency guard: bumped on every sold/quantity mutation so two
  // concurrent sale signals cannot both win. See lib/inventory/mark-sold.
  lockVersion           Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  photos                ItemPhoto[]
  marketplaceImages     MarketplaceImage[]
  aiOutputs             AiOutput[]
  listingDrafts         ListingDraft[]
  marketplaceListings   MarketplaceListing[]
  jobLogs               JobLog[]
  priceComps            PriceComp[]
  compSearchRuns        CompSearchRun[]
  inventoryEvents       InventoryEvent[]
  reviewTasks           ReviewTask[]
  bulkItem              BulkItem?
  saleSignals           MarketplaceSaleSignal[]

  @@unique([id, accountId])
  @@index([sellerId, status])
  @@index([accountId, status])
  @@index([createdAt])
}

model BulkBatch {
  id                String          @id @default(uuid()) @db.Uuid
  accountId         String          @db.Uuid
  account           Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdByUserId   String          @db.Uuid
  idempotencyKey    String?
  status            BulkBatchStatus @default(created)
  photoCount        Int             @default(0)
  totalItems        Int             @default(0)
  processedItems    Int             @default(0)
  needsReviewItems  Int             @default(0)
  listingReadyItems Int             @default(0)
  failedItems       Int             @default(0)
  canceledItems     Int             @default(0)
  canceledAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  items             BulkItem[]
  photos            BulkPhoto[]

  @@unique([id, accountId])
  @@unique([accountId, idempotencyKey])
  @@index([accountId, createdAt])
  @@index([accountId, status, updatedAt])
  @@index([createdByUserId, createdAt])
}

model BulkItem {
  id                  String         @id @default(uuid()) @db.Uuid
  batchId             String         @db.Uuid
  accountId           String         @db.Uuid
  batch               BulkBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  inventoryItemId     String?        @unique @db.Uuid
  inventoryItem       InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  position            Int
  status              BulkItemStatus @default(uploaded)
  reviewReason        String?
  errorCode           String?
  errorMessage        String?
  generationAttempts  Int            @default(0)
  aiProvider          String?
  aiModel             String?
  generationStartedAt DateTime?
  generationEndedAt   DateTime?
  canceledAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  photos              BulkPhoto[]

  @@unique([batchId, position])
  @@unique([id, batchId])
  @@index([accountId, status, updatedAt])
  @@index([batchId, status, position])
}

model BulkPhoto {
  id            String    @id @default(uuid()) @db.Uuid
  batchId       String    @db.Uuid
  accountId     String    @db.Uuid
  batch         BulkBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  bulkItemId    String?   @db.Uuid
  bulkItem      BulkItem? @relation(fields: [bulkItemId], references: [id], onDelete: SetNull)
  storageBucket String
  storagePath   String
  mimeType      String
  originalName  String
  position      Int
  itemPosition  Int?
  createdAt     DateTime  @default(now())

  @@unique([storageBucket, storagePath])
  @@unique([batchId, position])
  @@index([accountId, createdAt])
  @@index([batchId, bulkItemId, itemPosition])
}

model ItemPhoto {
  id                String             @id @default(uuid()) @db.Uuid
  inventoryItemId   String             @db.Uuid
  inventoryItem     InventoryItem      @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  storageBucket     String
  storagePath       String
  mimeType          String
  originalName      String
  position          Int
  createdAt         DateTime           @default(now())
  marketplaceImages MarketplaceImage[]

  @@unique([storageBucket, storagePath])
  @@index([inventoryItemId])
}

model MarketplaceImage {
  id              String                 @id @default(uuid()) @db.Uuid
  inventoryItemId String                 @db.Uuid
  inventoryItem   InventoryItem          @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  itemPhotoId     String                 @db.Uuid
  itemPhoto       ItemPhoto              @relation(fields: [itemPhotoId], references: [id], onDelete: Cascade)
  marketplace     Marketplace
  environment     String                 @default("sandbox")
  storagePath     String
  publicUrl       String
  status          MarketplaceImageStatus @default(READY)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([itemPhotoId, marketplace, environment])
  @@index([inventoryItemId, marketplace, environment, status])
}

model AiOutput {
  id              String        @id @default(uuid()) @db.Uuid
  inventoryItemId String        @db.Uuid
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  provider        String
  model           String
  kind            String
  promptVersion   String
  rawText         String?
  rawJson         Json?
  validatedJson   Json?
  errorMessage    String?
  createdAt       DateTime      @default(now())

  @@index([inventoryItemId, createdAt])
}

model ListingDraft {
  id                        String        @id @default(uuid()) @db.Uuid
  inventoryItemId           String        @db.Uuid
  inventoryItem             InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  status                    DraftStatus   @default(DRAFT)
  title                     String
  description               String
  bulletPoints              String[]
  recommendedPriceCents     Int?
  pricingRationale          String?
  itemSpecifics             Json
  marketplaceDrafts         Json
  measurements              Json?
  flaws                     Json?
  selectedMarketplaces      Marketplace[] @default([])
  stockxProductId           String?
  stockxVariantId           String?
  stockxMatchSource         String?
  stockxMatchConfidence     Float?
  stockxMarketDataCheckedAt DateTime?
  approvedAt                DateTime?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  @@index([inventoryItemId, status])
  @@index([stockxProductId])
  @@index([stockxVariantId])
}

model PriceComp {
  id               String         @id @default(uuid()) @db.Uuid
  inventoryItemId  String         @db.Uuid
  inventoryItem    InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  source           String
  sourceType       CompSourceType @default(manual)
  platform         String?
  status           CompStatus     @default(unknown)
  title            String
  brand            String?
  size             String?
  priceCents       Int
  shippingCents    Int            @default(0)
  totalPriceCents  Int?
  currency         String         @default("USD")
  soldDate         DateTime?
  url              String?
  imageUrl         String?
  condition        ItemCondition  @default(unknown)
  matchScore       Float?
  usedInPricing    Boolean        @default(true)
  ignoredAsOutlier Boolean        @default(false)
  rawJson          Json?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([inventoryItemId, createdAt])
}

model CompSearchRun {
  id                    String        @id @default(uuid()) @db.Uuid
  inventoryItemId       String        @db.Uuid
  inventoryItem         InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  status                String
  autoDiscoveryEnabled  Boolean       @default(false)
  sourceCount           Int           @default(0)
  fetchedCount          Int           @default(0)
  acceptedCount         Int           @default(0)
  rejectedCount         Int           @default(0)
  recommendedPriceCents Int?
  confidence            String?
  queries               Json
  sourcesChecked        String[]      @default([])
  sourceErrors          Json
  createdAt             DateTime      @default(now())

  @@index([inventoryItemId, createdAt])
}

// Append-only ledger of paid comp-provider calls (cost/quota accounting). Not
// cascaded from drafts/items: cost history must survive their deletion. Always
// seller-scoped (userId); RLS enabled as defense-in-depth.
model ProviderCallLedger {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @db.Uuid
  accountId          String?            @db.Uuid
  account            Account?           @relation(fields: [accountId], references: [id], onDelete: SetNull)
  draftId            String?            @db.Uuid
  inventoryItemId    String?            @db.Uuid
  provider           String
  status             ProviderCallStatus
  skippedReason      String?
  estimatedCostCents Int                @default(0)
  fetchedCount       Int                @default(0)
  acceptedCount      Int                @default(0)
  rejectedCount      Int                @default(0)
  queryHash          String?
  idempotencyKey     String?
  actualCostCents    Int?
  settledAt          DateTime?
  createdAt          DateTime           @default(now())

  @@index([userId, createdAt])
  @@index([accountId, createdAt])
  @@index([createdAt])
  @@index([draftId, createdAt])
}

// Alpha-user feedback. Seller-scoped reads (a user sees only their own); only
// admins (env allowlist) read all and triage. RLS on; not cascaded so feedback
// survives the referenced listing/draft.
model Feedback {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @db.Uuid
  type        FeedbackType
  severity    FeedbackSeverity @default(medium)
  marketplace String?
  subject     String
  message     String
  pageUrl     String?
  listingId   String?          @db.Uuid
  draftId     String?          @db.Uuid
  status      FeedbackStatus   @default(open)
  adminNotes  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model MarketplaceListing {
  id                String                   @id @default(uuid()) @db.Uuid
  inventoryItemId   String                   @db.Uuid
  inventoryItem     InventoryItem            @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  marketplace       Marketplace
  environment       String                   @default("sandbox")
  status            MarketplaceListingStatus @default(NOT_LISTED)
  sku               String?
  externalOfferId   String?
  externalListingId String?
  externalUrl       String?
  titleSnapshot     String?
  skuSnapshot       String?
  metadata          Json?
  lastSyncAt        DateTime?
  lastError         String?
  endedAt           DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  publishAttempts   PublishAttempt[]
  events            MarketplaceEvent[]

  @@unique([inventoryItemId, marketplace, environment])
  @@index([marketplace, status])
  @@index([marketplace, environment, status])
}

model PublishAttempt {
  id                   String               @id @default(uuid()) @db.Uuid
  marketplaceListingId String               @db.Uuid
  marketplaceListing   MarketplaceListing   @relation(fields: [marketplaceListingId], references: [id], onDelete: Cascade)
  status               PublishAttemptStatus @default(NOT_IMPLEMENTED)
  idempotencyKey       String?
  code                 String
  reason               String?
  adapterResult        Json?
  requestedBy          String               @db.Uuid
  startedAt            DateTime             @default(now())
  completedAt          DateTime?
  createdAt            DateTime             @default(now())
  // A partial UNIQUE index on (marketplaceListingId, idempotencyKey) WHERE
  // status IN ('QUEUED','RUNNING','SUCCEEDED') enforces at most one active or
  // successful publish/delist attempt per listing+key (the concurrency guard
  // against duplicate eBay side effects). Prisma cannot express partial unique
  // indexes, so it lives in migration 20260616130000_add_publish_attempt_idempotency_unique.

  @@index([marketplaceListingId, createdAt])
  @@index([requestedBy, createdAt])
  @@index([idempotencyKey])
}

model MarketplaceEvent {
  id                   String             @id @default(uuid()) @db.Uuid
  marketplaceListingId String             @db.Uuid
  marketplaceListing   MarketplaceListing @relation(fields: [marketplaceListingId], references: [id], onDelete: Cascade)
  kind                 String
  data                 Json?
  createdAt            DateTime           @default(now())

  @@index([marketplaceListingId, createdAt])
}

model MarketplaceConnection {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String             @db.Uuid
  accountId             String             @db.Uuid
  account               Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  marketplace           Marketplace
  environment           String
  externalUserId        String?
  accessTokenEnc        String
  refreshTokenEnc       String
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime?
  scopes                String[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  ebaySellerConfigs     EbaySellerConfig[]
  tiktokShopConfigs     TikTokShopConfig[]

  @@unique([userId, marketplace, environment])
  @@unique([accountId, marketplace, environment])
  @@index([userId])
  @@index([accountId])
  @@index([marketplace, environment])
}

model EbaySellerConfig {
  id                      String                @id @default(uuid()) @db.Uuid
  userId                  String                @db.Uuid
  accountId               String                @db.Uuid
  account                 Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  marketplaceConnectionId String                @db.Uuid
  marketplaceConnection   MarketplaceConnection @relation(fields: [marketplaceConnectionId], references: [id], onDelete: Cascade)
  marketplaceId           String                @default("EBAY_US")
  paymentPolicyId         String?
  fulfillmentPolicyId     String?
  returnPolicyId          String?
  merchantLocationKey     String?
  readinessStatus         String?
  readinessCheckedAt      DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@unique([userId, marketplaceConnectionId])
  @@unique([accountId, marketplaceConnectionId])
  @@index([userId])
  @@index([accountId])
  @@index([marketplaceConnectionId])
}

// Per-seller TikTok Shop connection state that lives beside the shared
// MarketplaceConnection (which holds the encrypted tokens). shop_cipher and the
// authorized shop id are required to sign TikTok Shop API requests; they are not
// secrets but are scoped to the seller and never logged.
model TikTokShopConfig {
  id                      String                @id @default(uuid()) @db.Uuid
  userId                  String                @db.Uuid
  accountId               String                @db.Uuid
  account                 Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  marketplaceConnectionId String                @db.Uuid
  marketplaceConnection   MarketplaceConnection @relation(fields: [marketplaceConnectionId], references: [id], onDelete: Cascade)
  shopId                  String?
  shopName                String?
  shopCipher              String?
  region                  String?
  sellerName              String?
  readinessStatus         String?
  readinessCheckedAt      DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  @@unique([userId, marketplaceConnectionId])
  @@unique([accountId, marketplaceConnectionId])
  @@index([userId])
  @@index([accountId])
  @@index([marketplaceConnectionId])
}

// External marketplace orders (TikTok Shop first). Deduplicated by
// (marketplace, environment, externalOrderId) so polling/webhooks are
// idempotent. Canonical inventory is only marked sold from reliable paid/
// confirmed statuses by the order-sync logic, never blindly from this row.
model MarketplaceOrder {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @db.Uuid
  marketplace       Marketplace
  environment       String      @default("production")
  externalOrderId   String
  externalShopId    String?
  status            String
  rawStatus         String?
  inventoryItemId   String?     @db.Uuid
  externalProductId String?
  externalSkuId     String?
  matched           Boolean     @default(false)
  payload           Json?
  lastEventAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([marketplace, environment, externalOrderId])
  @@index([userId, marketplace])
  @@index([inventoryItemId])
}

// Webhook/event de-duplication. A verified inbound event is recorded once;
// re-delivery of the same (marketplace, eventId) is a no-op. Only sanitized
// metadata is stored.
model MarketplaceWebhookEvent {
  id             String      @id @default(uuid()) @db.Uuid
  marketplace    Marketplace
  environment    String      @default("production")
  eventId        String
  eventType      String
  externalShopId String?
  processedAt    DateTime?
  payload        Json?
  createdAt      DateTime    @default(now())

  @@unique([marketplace, eventId])
  @@index([marketplace, eventType, createdAt])
}

// Cached TikTok Shop category rules/attributes. Category metadata is large and
// changes slowly; caching avoids re-fetching on every readiness check and lets
// readiness validate required attributes offline. fetchedAt drives TTL.
model TikTokCategoryCache {
  id           String   @id @default(uuid()) @db.Uuid
  region       String
  version      String   @default("v1")
  categoryId   String
  categoryName String?
  isLeaf       Boolean  @default(false)
  rules        Json?
  attributes   Json?
  fetchedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([region, version, categoryId])
  @@index([region, version])
}

model JobLog {
  id              String         @id @default(uuid()) @db.Uuid
  inventoryItemId String?        @db.Uuid
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  queueName       String
  jobName         String
  status          JobStatus
  payload         Json
  result          Json?
  errorMessage    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([inventoryItemId])
  @@index([queueName, status])
}

// ============================================================
// Inventory safety layer / double-sell prevention (Part 1).
// All tables follow the project RLS pattern: RLS enabled, no policies; access is
// the trusted resale_app role (BYPASSRLS), ownership enforced via userId filters.
// ============================================================

enum InventoryEventType {
  listing_created
  listing_active
  sale_detected
  sale_confirmed
  sale_rejected
  delist_requested
  delist_succeeded
  delist_failed
  manual_action_required
  notification_sent
  sync_conflict
}

enum SignalSource {
  api
  email
  manual
  system
}

enum ReviewTaskType {
  confirm_possible_sale
  manual_delist_required
  unmatched_marketplace_email
  sync_conflict
}

enum ReviewTaskStatus {
  open
  resolved
  dismissed
}

enum SyncJobType {
  detect_status
  mark_sold
  delist_marketplace_listing
  notify_user
  create_review_task
  update_inventory_quantity
  update_price
  sync_order
}

enum SyncJobStatus {
  queued
  running
  retry_wait
  succeeded
  failed
  skipped
  needs_review
  canceled
}

enum EmailSignalType {
  sale_detected
  offer_received
  listing_published
  listing_removed
  payment_received
  shipping_needed
  unknown
}

// Append-only, item-scoped audit trail of every safety action/signal.
model InventoryEvent {
  id              String             @id @default(uuid()) @db.Uuid
  inventoryItemId String             @db.Uuid
  inventoryItem   InventoryItem      @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  userId          String             @db.Uuid
  accountId       String?            @db.Uuid
  account         Account?           @relation(fields: [accountId], references: [id], onDelete: SetNull)
  type            InventoryEventType
  source          SignalSource
  marketplace     Marketplace?
  confidence      Float?
  payload         Json
  externalEventId String?
  correlationId   String?
  createdAt       DateTime           @default(now())

  @@index([inventoryItemId, createdAt])
  @@index([userId, createdAt])
  @@index([accountId, createdAt])
  @@index([marketplace, externalEventId])
}

// System-generated tasks requiring seller action (never auto-resolved).
model ReviewTask {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @db.Uuid
  accountId       String?          @db.Uuid
  account         Account?         @relation(fields: [accountId], references: [id], onDelete: SetNull)
  inventoryItemId String?          @db.Uuid
  inventoryItem   InventoryItem?   @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  marketplace     Marketplace?
  type            ReviewTaskType
  status          ReviewTaskStatus @default(open)
  title           String
  description     String
  payload         Json
  dedupeKey       String?
  createdAt       DateTime         @default(now())
  resolvedAt      DateTime?

  @@index([userId, status])
  @@index([accountId, status, createdAt])
  @@index([dedupeKey])
  @@index([inventoryItemId])
}

// Durable, idempotent sync/delist/notify job record. idempotencyKey is a FULL
// unique: enqueueing the same key twice is a no-op (retries bump attempts on the
// existing row), so marking sold twice can never duplicate delist jobs.
model SyncJob {
  id                   String        @id @default(uuid()) @db.Uuid
  userId               String        @db.Uuid
  accountId            String?       @db.Uuid
  account              Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)
  inventoryItemId      String?       @db.Uuid
  marketplaceListingId String?       @db.Uuid
  type                 SyncJobType
  status               SyncJobStatus @default(queued)
  attempts             Int           @default(0)
  maxAttempts          Int           @default(5)
  idempotencyKey       String        @unique
  errorCode            String?
  errorMessage         String?
  payload              Json
  runAfter             DateTime?
  lockedAt             DateTime?
  leaseOwner           String?
  retryClass           String?
  completedAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([status, runAfter])
  @@index([userId, createdAt])
  @@index([accountId, status, runAfter])
  @@index([inventoryItemId])
  @@index([marketplaceListingId])
}

// Parsed inbound marketplace emails (sale/payment/shipping signals). Deduped by
// providerMessageId so the same email is never reprocessed. Low-confidence rows
// never auto-delist; they create review tasks.
model EmailSignal {
  id                          String          @id @default(uuid()) @db.Uuid
  userId                      String?         @db.Uuid
  sourceEmail                 String
  destinationEmail            String
  marketplaceGuess            Marketplace?
  signalType                  EmailSignalType
  confidence                  Float
  subject                     String
  bodySnippet                 String
  parsedPayload               Json
  matchedInventoryItemId      String?         @db.Uuid
  matchedMarketplaceListingId String?         @db.Uuid
  providerMessageId           String?         @unique
  processedAt                 DateTime?
  createdAt                   DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([signalType, createdAt])
}

// Minimal in-app notification feed for safety events.
model Notification {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  accountId       String?   @db.Uuid
  account         Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  kind            String
  title           String
  body            String
  inventoryItemId String?   @db.Uuid
  dedupeKey       String?   @unique
  readAt          DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([accountId, createdAt])
  @@index([userId, readAt])
}

// --- Billing: accounts, subscriptions, usage metering, team seats ---------
// An Account owns the subscription and usage counters. One account per user to
// start (the owner); members are real once team seats ship. Billing and usage
// are account-keyed from day one so they never get rewritten when seats land.

enum PlanTier {
  free
  pro
  kingpin
}

enum MemberRole {
  owner
  admin
  member
}

enum MemberStatus {
  active
  invited
  revoked
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  incomplete
  incomplete_expired
  unpaid
}

enum UsageMetric {
  ai_listing
  autopublish
  comp_refresh
}

model Account {
  id          String   @id @default(uuid()) @db.Uuid
  ownerUserId String   @unique @db.Uuid
  plan        PlanTier @default(free)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  disabledAt  DateTime?
  disableReason String?

  members                AccountMember[]
  subscription           Subscription?
  usage                  UsageCounter[]
  inventory              InventoryItem[]
  marketplaceConnections MarketplaceConnection[]
  ebaySellerConfigs      EbaySellerConfig[]
  tiktokShopConfigs      TikTokShopConfig[]
  bulkBatches            BulkBatch[]
  providerCalls          ProviderCallLedger[]
  usageReservations      UsageReservation[]
  inventoryEvents        InventoryEvent[]
  reviewTasks            ReviewTask[]
  syncJobs               SyncJob[]
  notifications          Notification[]
  saleSignals            MarketplaceSaleSignal[]
}

model AccountMember {
  id           String       @id @default(uuid()) @db.Uuid
  accountId    String       @db.Uuid
  userId       String?      @db.Uuid
  invitedEmail String?
  role         MemberRole   @default(member)
  status       MemberStatus @default(invited)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@index([userId])
  @@index([accountId, status])
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  accountId            String             @unique @db.Uuid
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  plan                 PlanTier           @default(free)
  status               SubscriptionStatus @default(active)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  graceEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model UsageCounter {
  id          String      @id @default(uuid()) @db.Uuid
  accountId   String      @db.Uuid
  metric      UsageMetric
  periodStart DateTime    @db.Date
  count       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, metric, periodStart])
  @@index([accountId, periodStart])
}

model UsageReservation {
  id               String                 @id @default(uuid()) @db.Uuid
  accountId        String                 @db.Uuid
  account          Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  metric           UsageMetric
  periodStart      DateTime               @db.Date
  idempotencyKey   String
  units            Int                    @default(1)
  status           UsageReservationStatus @default(reserved)
  planSnapshot     PlanTier
  limitSnapshot    Int
  denialReason     String?
  reservedByUserId String?                @db.Uuid
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  settledAt        DateTime?
  releasedAt       DateTime?

  @@unique([accountId, metric, idempotencyKey])
  @@index([accountId, metric, periodStart, status])
  @@index([status, createdAt])
}

model MarketplaceSaleSignal {
  id                    String      @id @default(uuid()) @db.Uuid
  accountId             String      @db.Uuid
  account               Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  inventoryItemId       String?     @db.Uuid
  inventoryItem         InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  marketplace           Marketplace
  environment           String      @default("production")
  externalEventId       String
  externalOrderId       String?
  externalLineItemId    String?
  externalListingId     String?
  state                 String
  outcome               String?
  sanitizedPayload      Json
  processedAt           DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@unique([accountId, marketplace, environment, externalEventId])
  @@index([accountId, marketplace, createdAt])
  @@index([inventoryItemId, createdAt])
  @@index([externalOrderId, externalLineItemId])
}

model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
}
