{
  "name": "resale-crosslister",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "prisma generate && tsc --noEmit --pretty false",
    "test": "vitest run",
    "agent:start": "tsx scripts/agent-workflow/cli.ts start",
    "agent:status": "tsx scripts/agent-workflow/cli.ts status",
    "agent:check": "tsx scripts/agent-workflow/cli.ts check",
    "agent:finish": "tsx scripts/agent-workflow/cli.ts finish",
    "agent:review": "tsx scripts/agent-workflow/cli.ts review",
    "agent:cleanup": "tsx scripts/agent-workflow/cli.ts cleanup",
    "agent:ci": "tsx scripts/agent-workflow/cli.ts ci",
    "agent:test": "vitest run scripts/agent-workflow",
    "validate:scoped": "npm run agent:test && npm run lint && npm run typecheck && npm run prisma:validate",
    "validate:full": "npm run lint && npm run typecheck && npm test && npm run prisma:validate && npm run build",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "prisma:validate": "prisma validate"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bullmq": "^5.79.3",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^22.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^25.9.5",
    "@types/pg": "^8.20.0",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native": "npm:typescript@^7.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "picomatch": "^4.0.5",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "postcss": "8.5.15",
    "@hono/node-server": "2.0.4"
  }
}
