REDIS_URL="redis://localhost:6379"

# eBay sandbox (Phase 3 publishing; sandbox-only, not needed for the Phase 1 workbench)
EBAY_ENV="sandbox"
EBAY_CLIENT_ID="[EBAY_CLIENT_ID]"
