DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT_REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[PROJECT_REF].supabase.co:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[SUPABASE_ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SUPABASE_SERVICE_ROLE_KEY]"
SUPABASE_STORAGE_BUCKET="listing-photos"
# Public Supabase Storage bucket used only for marketplace-safe derivative media.
# Leave unset in Production until the bucket is created/configured and verified.
EBAY_PUBLIC_IMAGE_BUCKET="sello-ebay-public-listing-photos"

GEMINI_API_KEY="[GEMINI_API_KEY]"
GEMINI_MODEL="gemini-2.5-flash"

EBAY_ENV="sandbox"
EBAY_CLIENT_ID="[EBAY_SANDBOX_CLIENT_ID]"
EBAY_CLIENT_SECRET="[EBAY_SANDBOX_CLIENT_SECRET]"
EBAY_REDIRECT_URI_NAME="[EBAY_SANDBOX_RUNAME]"
EBAY_MARKETPLACE_ID="EBAY_US"
EBAY_TOKEN_ENCRYPTION_KEY="[32_BYTE_HEX_KEY]"
EBAY_OAUTH_STATE_SECRET="[STRONG_RANDOM_SECRET]"
EBAY_SANDBOX_PUBLISH_ENABLED="false"
EBAY_PRODUCTION_PUBLISH_ENABLED="false"

# --- Alpha live actions ------------------------------------------------------
# Per-feature allowlists (server-only, comma-separated emails). Empty = nobody
# (fail closed). These gate LIVE mutations independently of the global switches
# above; preview/preflight stays available to every authenticated seller. Do not
# reuse ADMIN_EMAILS as a fallback for these.
LIVE_EBAY_PUBLISH_EMAILS=""
EBAY_DELIST_EMAILS=""
PAID_COMPS_EMAILS=""

# Admin surface gate (admin pages + /api/admin/*). Comma-separated. Empty = no
# admins (fail closed). Separate from the product allowlists above.
ADMIN_EMAILS=""
ADMIN_USER_IDS=""

# Bulk eBay publish transport controls. There is NO seller-visible item cap; the
# ceiling is a high transport limit and the client chunks larger selections
# internally. Concurrency is clamped to 1..3 server-side.
BULK_PUBLISH_MAX_ITEMS="1000"
BULK_PUBLISH_CHUNK_SIZE="20"
BULK_PUBLISH_CONCURRENCY="2"

PRICE_COMP_AUTO_DISCOVERY_ENABLED="false"
PRICE_COMP_EBAY_SEARCH_ENABLED="false"
COMPS_AUTO_DISCOVERY_ENABLED="false"
COMPS_EBAY_ACTIVE_ENABLED="false"
EBAY_BROWSE_CLIENT_ID="[OPTIONAL_EBAY_BROWSE_CLIENT_ID_OR_USE_EBAY_CLIENT_ID]"
EBAY_BROWSE_CLIENT_SECRET="[OPTIONAL_EBAY_BROWSE_CLIENT_SECRET_OR_USE_EBAY_CLIENT_SECRET]"
EBAY_BROWSE_MARKETPLACE_ID="EBAY_US"
PRICE_COMP_EBAY_MARKETPLACE_INSIGHTS_ENABLED="false"
EBAY_MARKETPLACE_INSIGHTS_ACCESS_APPROVED="false"

PRICE_COMP_APIFY_EBAY_SOLD_ENABLED="false"
COMPS_APIFY_EBAY_SOLD_ENABLED="false"
APIFY_TOKEN="[APIFY_API_TOKEN]"
APIFY_EBAY_SOLD_ACTOR="[apify_actor_id_or_slug]"
COMPS_SERPAPI_EBAY_ACTIVE_ENABLED="false"
SERPAPI_API_KEY="[OPTIONAL_SERPAPI_API_KEY]"
COMPS_REFRESH_COOLDOWN_SECONDS="60"
COMPS_MAX_PROVIDER_RESULTS="20"
COMPS_MAX_QUERY_VARIANTS="2"
COMPS_AUTO_MIN_IDENTITY_CONFIDENCE="0.55"
# Paid comp-provider controls. Keep the global switch off until rollout checks pass.
# The values below are safe LOCAL defaults. Intended PRODUCTION caps (set these
# in the Production env): COMPS_APIFY_DAILY_BUDGET_CENTS=500,
# COMPS_USER_DAILY_PROVIDER_CALL_LIMIT=5, COMPS_USER_MONTHLY_PROVIDER_CALL_LIMIT=25,
# COMPS_REFRESH_COOLDOWN_SECONDS=3600, COMPS_DRAFT_PROVIDER_COOLDOWN_SECONDS=3600,
# COMPS_MAX_PROVIDER_RESULTS=10, COMPS_MAX_QUERY_VARIANTS=1,
# COMPS_ADMIN_OVERRIDE_ENABLED=false.
COMPS_PAID_PROVIDERS_ENABLED="false"
COMPS_ADMIN_OVERRIDE_ENABLED="false"
COMPS_APIFY_DAILY_BUDGET_CENTS="200"
COMPS_USER_DAILY_PROVIDER_CALL_LIMIT="2"
COMPS_USER_MONTHLY_PROVIDER_CALL_LIMIT="20"
COMPS_DRAFT_PROVIDER_COOLDOWN_SECONDS="86400"
COMPS_APIFY_ESTIMATED_COST_CENTS="35"
PRICE_COMP_DEPOP_ACTIVE_ENABLED="false"
PRICE_COMP_GOOGLE_LENS_ENABLED="false"
PRICE_COMP_GRAILED_SOLD_ENABLED="false"
PRICE_COMP_POSHMARK_SOLD_ENABLED="false"
PRICE_COMP_STOCKX_ENABLED="false"

REDIS_URL="redis://localhost:6379"
