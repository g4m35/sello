COMPS_USER_DAILY_PROVIDER_CALL_LIMIT="2"
COMPS_USER_MONTHLY_PROVIDER_CALL_LIMIT="20"
COMPS_DRAFT_PROVIDER_COOLDOWN_SECONDS="86400"
COMPS_APIFY_ESTIMATED_COST_CENTS="35"
PRICE_COMP_DEPOP_ACTIVE_ENABLED="false"
PRICE_COMP_GOOGLE_LENS_ENABLED="false"
PRICE_COMP_GRAILED_SOLD_ENABLED="false"
PRICE_COMP_POSHMARK_SOLD_ENABLED="false"
