+  mkdirSync(remote);
+  git(remote, "init", "--bare");
+  git(root, "remote", "add", "origin", remote);
+  git(root, "push", "-u", "origin", "develop");
+  return { root, remote, scratch };
+}
+
+function contract(root: string, overrides: Partial<TaskContract> = {}): TaskContract {
+  return {
+    id: "test-task-001",
+    title: "Test task",
+    status: "ready",
+    owner: "Cursor/Grok",
+    reviewer: "Codex",
+    risk: "low",
